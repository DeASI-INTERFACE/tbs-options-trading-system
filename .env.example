# TBS Options Trading System - Environment Configuration
# Copyright (c) 2026 De-ASI-INTERFACE / Richard Patterson

# Broker / Exchange API
BROKER_API_KEY=your_api_key_here
BROKER_API_SECRET=your_api_secret_here
BROKER_BASE_URL=https://api.broker.com/v1
BROKER_WS_URL=wss://stream.broker.com/ws

# Paper / Live Trading
TRADING_MODE=paper
ACCOUNT_ID=your_account_id

# Risk Configuration
MAX_PORTFOLIO_DELTA=500
MAX_SINGLE_VEGA_PCT=0.02
DAILY_DRAWDOWN_LIMIT_PCT=0.03
GAMMA_SPIKE_THRESHOLD=0.05

# Data Feeds
MARKET_DATA_PROVIDER=polygon
MARKET_DATA_API_KEY=your_key_here

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3000
LOG_LEVEL=info

# Bot Range
BOT_START_ID=1
BOT_END_ID=100
