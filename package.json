{
  "name": "tbs-options-trading-system",
  "version": "1.0.0",
  "description": "TBS #1-#100 Institutional-Grade Options Trading Bot System",
  "author": "De-ASI-INTERFACE / Richard Patterson",
  "license": "MIT",
  "private": false,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bot": "ts-node src/index.ts",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "backtest": "ts-node src/scripts/backtest.ts",
    "health": "ts-node src/scripts/health-check.ts",
    "generate:configs": "ts-node src/scripts/generate-configs.ts",
    "docker:build": "docker build -t tbs-options-bot .",
    "docker:up": "docker compose up"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.16.0",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0",
    "mathjs": "^12.3.0",
    "date-fns": "^3.3.0",
    "js-yaml": "^4.1.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.2.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.ts"],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": { "lines": 80, "functions": 80, "branches": 70 }
    }
  }
}
